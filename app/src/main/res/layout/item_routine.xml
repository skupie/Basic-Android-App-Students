<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginBottom="10dp">

    <!-- Left: time label + dot -->
    <LinearLayout
        android:layout_width="68dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end|top"
        android:paddingEnd="6dp"
        android:paddingTop="14dp">

        <TextView
            android:id="@+id/tvTimeSlot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/brand_light"
            android:textSize="10sp"
            android:textStyle="bold"
            android:gravity="end"
            android:maxLines="2"/>

        <!-- Dot -->
        <View
            android:id="@+id/viewTimelineDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_gravity="end"
            android:layout_marginTop="4dp"
            android:background="@drawable/ic_circle"/>
    </LinearLayout>

    <!-- Color accent line -->
    <View
        android:id="@+id/viewAccentLine"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"
        android:layout_marginStart="4dp"
        android:background="@color/brand_primary"/>

    <!-- Card content -->
    <LinearLayout
        android:id="@+id/cardRoutine"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="@drawable/bg_card_dark"
        android:orientation="vertical"
        android:paddingStart="14dp" android:paddingEnd="14dp"
        android:paddingTop="14dp" android:paddingBottom="14dp"
        android:layout_marginStart="8dp">

        <TextView
            android:id="@+id/tvSubject"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvTeacher"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_hint"
            android:textSize="12sp"
            android:layout_marginTop="3dp"/>

        <!-- Time range in accent color -->
        <TextView
            android:id="@+id/tvTimeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginTop="6dp"
            android:textColor="@color/brand_light"/>
    </LinearLayout>
</LinearLayout>
