<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:background="@drawable/bg_card_dark"
    android:padding="14dp" android:layout_marginBottom="9dp">

    <androidx.cardview.widget.CardView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/cardPayIcon"
        android:layout_width="44dp" android:layout_height="44dp"
        app:cardCornerRadius="14dp" app:cardElevation="0dp"
        android:layout_marginEnd="14dp">
        <TextView android:id="@+id/tvPayModeIcon"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:gravity="center" android:textSize="20sp"/>
    </androidx.cardview.widget.CardView>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvPayMonth"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/text_primary" android:textSize="13sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvPayMeta"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/text_hint" android:textSize="11sp" android:layout_marginTop="2dp"/>
    </LinearLayout>

    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="end">
        <TextView android:id="@+id/tvPayAmount"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/success" android:textSize="16sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvPayDate"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/text_muted" android:textSize="11sp" android:layout_marginTop="2dp"/>
    </LinearLayout>
</LinearLayout>
