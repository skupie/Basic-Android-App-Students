<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingTop="18dp" android:paddingBottom="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fees &amp; Payments"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- ── Fee Summary Hero Card ── -->
    <LinearLayout
        android:id="@+id/cardDueSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_hero_amber"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:padding="20dp"
        android:visibility="gone">

        <!-- Card title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠"
                android:textColor="#FCA5A5"
                android:textSize="13sp"
                android:layout_marginEnd="6dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FEE SUMMARY"
                android:textColor="#FCA5A5"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"/>
        </LinearLayout>

        <!-- Row 1: Monthly Fee -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Monthly Fee"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"/>
            <TextView
                android:id="@+id/tvMonthlyFee"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#33FFFFFF" android:layout_marginBottom="10dp"/>

        <!-- Row 2: Due Months — badge + names on the right -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Due Months"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"/>
            <!-- e.g. "2 Months" -->
            <TextView
                android:id="@+id/tvOverdueBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill_warning"
                android:paddingStart="10dp" android:paddingEnd="10dp"
                android:paddingTop="4dp" android:paddingBottom="4dp"
                android:textColor="@color/warning_light"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"/>
            <!-- e.g. "February &amp; March" -->
            <TextView
                android:id="@+id/tvDueMonths"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#33FFFFFF" android:layout_marginBottom="10dp"/>

        <!-- Row 3: Total Due (large, highlighted) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="18dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Total Due"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvTotalDue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/warning_light"
                android:textSize="24sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Pay Now button — full width -->
        <TextView
            android:id="@+id/btnPayNow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_primary"
            android:paddingTop="13dp" android:paddingBottom="13dp"
            android:gravity="center"
            android:text="Pay Now →"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- ── Pill Tab Selector ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_card_dark"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
        android:layout_marginBottom="14dp"
        android:padding="4dp">

        <TextView
            android:id="@+id/tabInvoices"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Invoices"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_tab_selected"
            android:textColor="@color/text_primary"/>

        <TextView
            android:id="@+id/tabPayments"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Payments"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@null"
            android:textColor="@color/text_hint"/>
    </LinearLayout>

    <!-- ── List ── -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerFees"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:paddingTop="4dp" android:paddingBottom="80dp"
            android:clipToPadding="false"/>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>
