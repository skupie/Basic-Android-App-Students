<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_modal"
    android:padding="0dp"
    android:clipToPadding="false">

    <!-- ── Top accent bar ── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="@drawable/bg_hero_danger"
        android:layout_marginBottom="0dp"/>

    <!-- ── Content ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Icon + title row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <!-- Red circle icon -->
            <FrameLayout
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_due_icon_circle"
                android:layout_marginEnd="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="!"
                    android:textColor="#EF4444"
                    android:textSize="26sp"
                    android:textStyle="bold"/>
            </FrameLayout>

            <!-- Title col -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PAYMENT DUE"
                    android:textColor="#EF4444"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvDialogTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fee Payment Overdue"
                    android:textColor="#F3F4F6"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1A2236"
            android:layout_marginBottom="20dp"/>

        <!-- Message body -->
        <TextView
            android:id="@+id/tvDialogBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#9CA3AF"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.6"
            android:layout_marginBottom="20dp"/>

        <!-- Amount card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card_danger"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="মোট বকেয়া"
                    android:textColor="#FCA5A5"
                    android:textSize="11sp"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Due Amount"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvDialogAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#EF4444"
                android:textSize="22sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- OK button -->
        <Button
            android:id="@+id/btnDialogOk"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_btn_danger"
            android:text="ঠিক আছে"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            android:stateListAnimator="@null"/>

    </LinearLayout>
</LinearLayout>
