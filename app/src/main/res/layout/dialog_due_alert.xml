<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#FFFFFF"
    android:clipChildren="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Gradient header ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_hero_danger"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="বকেয়া ফি সতর্কতা"
                    android:textColor="#FFEEEE"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvDialogTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ফি পরিশোধ বাকি আছে"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="অনুগ্রহ করে পড়ুন এবং ব্যবস্থা নিন।"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- DUE badge -->
            <LinearLayout
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:gravity="center"
                android:background="@color/white"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="বকেয়া"
                    android:textColor="@color/danger"
                    android:textSize="11sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ── Body ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFF8F8"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvDialogBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#333333"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.6"
                android:layout_marginBottom="20dp"/>

            <!-- Amount row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="মোট বকেয়া"
                    android:textColor="#666666"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tvDialogAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/danger"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- OK button -->
            <Button
                android:id="@+id/btnDialogOk"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_btn_primary"
                android:text="ঠিক আছে"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:stateListAnimator="@null"/>
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
