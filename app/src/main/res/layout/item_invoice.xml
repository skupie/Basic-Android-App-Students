<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cardInvoice"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card_dark"
    android:padding="16dp" android:layout_marginBottom="10dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="12dp">
        <TextView android:id="@+id/tvMonth"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvStatus"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:paddingStart="12dp" android:paddingEnd="12dp"
            android:paddingTop="4dp" android:paddingBottom="4dp"
            android:textSize="11sp" android:textStyle="bold"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/border_default" android:layout_marginBottom="10dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="10dp">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="DUE" android:textColor="@color/text_muted"
                android:textSize="10sp" android:textAllCaps="true" android:letterSpacing="0.06"/>
            <TextView android:id="@+id/tvAmountDue"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold"
                android:layout_marginTop="3dp"/>
        </LinearLayout>
        <View android:layout_width="1dp" android:layout_height="match_parent"
            android:background="@color/border_default"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="PAID" android:textColor="@color/text_muted"
                android:textSize="10sp" android:textAllCaps="true" android:letterSpacing="0.06"/>
            <TextView android:id="@+id/tvAmountPaid"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/success" android:textSize="14sp" android:textStyle="bold"
                android:layout_marginTop="3dp"/>
        </LinearLayout>
        <View android:layout_width="1dp" android:layout_height="match_parent"
            android:background="@color/border_default"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="BALANCE" android:textColor="@color/text_muted"
                android:textSize="10sp" android:textAllCaps="true" android:letterSpacing="0.06"/>
            <TextView android:id="@+id/tvOutstanding"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="14sp" android:textStyle="bold" android:layout_marginTop="3dp"/>
        </LinearLayout>
    </LinearLayout>

    <TextView android:id="@+id/tvDueDate"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="@color/text_hint" android:textSize="11sp"/>

</LinearLayout>
