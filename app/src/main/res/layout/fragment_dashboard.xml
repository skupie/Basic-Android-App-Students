<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:clipToPadding="false"
    android:paddingBottom="88dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="12dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Good Morning 👋"
                    android:textColor="@color/text_hint"
                    android:textSize="13sp"/>
                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Student"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnNotifications"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_icon_btn"
                android:src="@android:drawable/ic_popup_reminder"
                android:tint="@color/text_secondary"
                android:layout_marginEnd="10dp"
                android:padding="8dp"
                android:contentDescription="Notifications"/>

            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_icon_btn"
                android:src="@android:drawable/ic_menu_manage"
                android:tint="@color/text_secondary"
                android:padding="8dp"
                android:contentDescription="Settings"/>
        </LinearLayout>

        <!-- Hero Student Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardStudentProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="@color/brand_dark"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_hero_indigo"
                android:padding="20dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">
                    <TextView
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="STUDENT PROFILE"
                        android:textColor="#B3FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>
                    <TextView
                        android:id="@+id/tvActiveStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_pill_brand"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:text="● ACTIVE"
                        android:textColor="@color/brand_light"
                        android:textSize="11sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvStudentClass"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Class X — Science"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvAcademicYear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Academic Year 2025–26"
                    android:textColor="#99FFFFFF"
                    android:textSize="12sp"
                    android:layout_marginBottom="16dp"/>

                <!-- Stats Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:id="@+id/tvAttendancePct"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/white" android:textSize="20sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Attendance"
                            android:textColor="#80FFFFFF" android:textSize="11sp"/>
                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="match_parent"
                        android:background="#33FFFFFF" android:layout_marginEnd="16dp"/>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:id="@+id/tvAvgScore"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/white" android:textSize="20sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Avg. Score"
                            android:textColor="#80FFFFFF" android:textSize="11sp"/>
                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="match_parent"
                        android:background="#33FFFFFF" android:layout_marginEnd="16dp"/>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:id="@+id/tvDueFees"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/warning_light" android:textSize="20sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Due Fees"
                            android:textColor="#80FFFFFF" android:textSize="11sp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Quick Access -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="QUICK ACCESS"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="14dp">

            <LinearLayout android:id="@+id/quickAttendance"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="@drawable/bg_card_dark"
                android:padding="14dp" android:gravity="center"
                android:layout_marginEnd="5dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📅" android:textSize="22sp" android:layout_marginBottom="6dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Attend" android:textColor="@color/text_secondary" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/quickFees"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="@drawable/bg_card_dark"
                android:padding="14dp" android:gravity="center"
                android:layout_marginStart="5dp" android:layout_marginEnd="5dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="💳" android:textSize="22sp" android:layout_marginBottom="6dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Fees" android:textColor="@color/text_secondary" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/quickResults"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="@drawable/bg_card_dark"
                android:padding="14dp" android:gravity="center"
                android:layout_marginStart="5dp" android:layout_marginEnd="5dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📊" android:textSize="22sp" android:layout_marginBottom="6dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Results" android:textColor="@color/text_secondary" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/quickMaterials"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="@drawable/bg_card_dark"
                android:padding="14dp" android:gravity="center"
                android:layout_marginStart="5dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📚" android:textSize="22sp" android:layout_marginBottom="6dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Notes" android:textColor="@color/text_secondary" android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Due Alert -->
        <LinearLayout
            android:id="@+id/cardDueAlert"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_card_danger"
            android:padding="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">
            <LinearLayout android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/bg_pill_danger" android:gravity="center"
                android:layout_marginEnd="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="⚠️" android:textSize="18sp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Fee Payment Overdue"
                    android:textColor="@color/danger_light" android:textSize="13sp" android:textStyle="bold"/>
                <TextView android:id="@+id/tvDueAlertMsg"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Tap to pay"
                    android:textColor="@color/text_secondary" android:textSize="12sp" android:layout_marginTop="2dp"/>
            </LinearLayout>
            <TextView android:id="@+id/tvDueAlertAmount"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/danger" android:textSize="15sp" android:textStyle="bold"/>
        </LinearLayout>

        <!-- Today's Classes -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TODAY'S CLASSES"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="10dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTodaySchedule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:nestedScrollingEnabled="false"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
