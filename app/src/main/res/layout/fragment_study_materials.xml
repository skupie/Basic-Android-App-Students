<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingTop="18dp" android:paddingBottom="12dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="38dp" android:layout_height="38dp"
            android:background="@drawable/bg_icon_btn"
            android:src="@drawable/ic_back_arrow"
            android:padding="8dp"
            android:contentDescription="Back"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Study Materials"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- ── Search bar ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_input_field"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        android:paddingStart="14dp" android:paddingEnd="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍"
            android:textSize="14sp"
            android:layout_marginEnd="8dp"/>

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@null"
            android:hint="Search notes, chapters..."
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:inputType="text"
            android:maxLines="1"
            android:imeOptions="actionSearch"/>
    </LinearLayout>

    <!-- ── Subject filter chips ── -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="12dp"
        android:paddingStart="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/chipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingEnd="16dp">

            <!-- "All" chip — active by default, others added programmatically -->
            <TextView
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/bg_pill_brand"
                android:paddingStart="18dp" android:paddingEnd="18dp"
                android:paddingTop="7dp" android:paddingBottom="7dp"
                android:layout_marginEnd="8dp"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- ── Stats row ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp">

        <!-- Total Files -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/bg_card_dark"
            android:padding="12dp"
            android:layout_marginEnd="6dp">

            <TextView
                android:id="@+id/tvTotalFiles"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/brand_light"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Files"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- This Week -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/bg_card_dark"
            android:padding="12dp"
            android:layout_marginEnd="6dp">

            <TextView
                android:id="@+id/tvThisWeek"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/success"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="This Week"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Subjects -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/bg_card_dark"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvSubjectCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/grade_average"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Subjects"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No materials available"
        android:textColor="@color/text_hint"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone"/>

    <!-- ── List ── -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerMaterials"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:paddingTop="4dp" android:paddingBottom="80dp"
            android:clipToPadding="false"/>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
</LinearLayout>
