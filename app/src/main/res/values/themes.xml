<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.StudentPortal" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryVariant">@color/brand_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorError">@color/danger</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_secondary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="bottomNavigationStyle">@style/Widget.StudentPortal.BottomNav</item>
        <item name="tabStyle">@style/Widget.StudentPortal.TabLayout</item>
    </style>

    <!-- Fintech Bottom Nav -->
    <style name="Widget.StudentPortal.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/bg_secondary</item>
        <item name="itemIconTint">@color/bottom_nav_tint</item>
        <item name="itemTextColor">@color/bottom_nav_tint</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- Tabs -->
    <style name="Widget.StudentPortal.TabLayout" parent="Widget.MaterialComponents.TabLayout">
        <item name="android:background">@color/bg_surface</item>
        <item name="tabTextColor">@color/text_muted</item>
        <item name="tabSelectedTextColor">@color/text_primary</item>
        <item name="tabIndicatorColor">@color/brand_primary</item>
        <item name="tabIndicatorHeight">2dp</item>
    </style>

    <!-- Card style -->
    <style name="Widget.StudentPortal.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="strokeColor">@color/border_default</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">16dp</item>
    </style>

    <!-- Hero Card (gradient — set in code) -->
    <style name="Widget.StudentPortal.HeroCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/brand_dark</item>
        <item name="cardElevation">16dp</item>
        <item name="cardCornerRadius">20dp</item>
    </style>

    <!-- Base TextAppearance — required as implicit parent for dot-notation sub-styles below -->
    <style name="TextAppearance.StudentPortal" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Text styles -->
    <style name="TextAppearance.StudentPortal.PageTitle">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.StudentPortal.SectionLabel">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="TextAppearance.StudentPortal.HeroAmount">
        <item name="android:textSize">34sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:letterSpacing">-0.03</item>
    </style>

    <!-- Buttons -->
    <style name="Widget.StudentPortal.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/brand_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Widget.StudentPortal.Button.Danger" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/danger</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">10dp</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- Input fields -->
    <style name="Widget.StudentPortal.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">#0F1824</item>
        <item name="boxStrokeColor">@color/border_default</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="hintTextColor">@color/text_hint</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <!-- Chip style -->
    <style name="Widget.StudentPortal.Chip" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="chipBackgroundColor">@color/bg_surface</item>
        <item name="chipStrokeColor">@color/border_default</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="chipCornerRadius">20dp</item>
    </style>
</resources>
