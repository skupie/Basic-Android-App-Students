<?xml version="1.0" encoding="utf-8"?>
<!--
    Used ONLY by values-v31/themes.xml windowSplashScreenAnimatedIcon.
    Replicates the exact same glow layers from bg_logo_glow.xml + the logo
    so the system splash (Android 12+) matches the custom SplashActivity.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer soft glow — matches bg_logo_glow layer 1 -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="50%"
                android:centerColor="#336366F1"
                android:endColor="#00000000"/>
        </shape>
    </item>

    <!-- Middle glow ring — matches bg_logo_glow layer 2 -->
    <item
        android:top="18dp"
        android:bottom="18dp"
        android:left="18dp"
        android:right="18dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="50%"
                android:centerColor="#556366F1"
                android:endColor="#00000000"/>
        </shape>
    </item>

    <!-- Inner bright core glow — matches bg_logo_glow layer 3 -->
    <item
        android:top="36dp"
        android:bottom="36dp"
        android:left="36dp"
        android:right="36dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="50%"
                android:centerColor="#886366F1"
                android:endColor="#006366F1"/>
        </shape>
    </item>

    <!-- Logo on top of glow — same sizing ratio as activity_splash.xml (120/180 = 67%) -->
    <item
        android:top="24dp"
        android:bottom="24dp"
        android:left="24dp"
        android:right="24dp">
        <bitmap
            android:src="@drawable/ic_logo"
            android:gravity="fill"/>
    </item>

</layer-list>
